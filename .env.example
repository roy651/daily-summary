# Copy to .env for local development ONLY. Never commit a real .env.
# In production, credentials live in the macOS Keychain, not in a .env file.

# --- IMAP (read-only mailbox access; shared with the sibling's mail-evidence) ---
# Use an app-password, not the main account password.
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=replace_me
IMAP_APP_PASSWORD=replace_me

# --- Reasoning seam ---
# session = supervised Claude session (default, MVP); api = headless Anthropic API (phase 2);
# replay = load a fixture model_output.json (tests).
REASONER=session

# --- Delivery ---
# file = write digest + todos to ./out (default, MVP); email = send to Avigail + parse replies.
DELIVERY=file
# Required when DELIVERY=email. Allowlist of recipient(s) — Avigail's own address ONLY.
DIGEST_EMAIL_TO=replace_me
# SMTP (only used when DELIVERY=email). App-password, not the main password.
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=replace_me
SMTP_APP_PASSWORD=replace_me

# --- Bootstrap ---
# One-time cold-start: the sibling's exported mail tree, read once via ingest_email_export.
SIBLING_EXPORT_ROOT=../private/invoicing-assistant/fixtures/emails

# --- Behavior flags ---
# true = report what it WOULD send/write without performing network sends.
DRY_RUN=true
