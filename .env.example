# Copy to .env for local development ONLY. Never commit a real .env.
# In production, prefer the macOS Keychain over a .env file.

# --- Incoming mail (read-only IMAP) ---
# One or more mailboxes. Each is pulled every run with its OWN watermark; threads dedup by
# Message-ID, so overlap is safe. Use app-passwords, never the main account password.
IMAP_ACCOUNTS=ula,gmail

IMAP_ULA_HOST=mail.example.com
IMAP_ULA_PORT=993
IMAP_ULA_USER=replace_me
IMAP_ULA_APP_PASSWORD=replace_me

IMAP_GMAIL_HOST=imap.gmail.com
IMAP_GMAIL_PORT=993
IMAP_GMAIL_USER=replace_me
IMAP_GMAIL_APP_PASSWORD=replace_me
IMAP_GMAIL_SENT='[Gmail]/Sent Mail'
# (Single-account alternative: omit IMAP_ACCOUNTS and set IMAP_HOST/IMAP_PORT/IMAP_USER/IMAP_APP_PASSWORD.)

# --- Reasoning seam (REASONER) ---
# code = headless Claude Code (`claude -p`) on your Claude subscription, no API key (DEFAULT);
# session = supervised Claude session; api = cloud (see below); replay = fixture (tests).
REASONER=code
# CLAUDE_BIN=claude
# CLAUDE_MODEL=opus

# Cloud backend for REASONER=api only (run `uv sync --extra api`):
#   anthropic -> Anthropic SDK (LLM_API_KEY or ANTHROPIC_API_KEY)
#   openai    -> any OpenAI-compatible endpoint, e.g. OpenRouter (set LLM_BASE_URL)
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=anthropic/claude-opus-4
# LLM_API_KEY=replace_me

# --- Outbound digest (DELIVERY) ---
# file = write ./out (no network); email = send to Avigail (recipient hard-allowlisted).
DELIVERY=email
# The ONLY allowed recipient — Avigail's own address. A non-allowlisted recipient raises.
DIGEST_EMAIL_TO=replace_me
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=replace_me
SMTP_APP_PASSWORD=replace_me

# --- Bootstrap (one-time cold start / offline replay source) ---
SIBLING_EXPORT_ROOT=fixtures

# Preview vs send is the single `--dry-run` CLI flag (no env knob):
#   daily --dry-run  -> pull + reason + write out/ artifacts, but DON'T send / persist / move watermark
#   daily            -> real run: send, persist, advance watermarks
